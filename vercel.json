{
  "version": 2,
  "builds": [
    { "src": "web/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" },
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/style.css", "dest": "/web/style.css" },
    { "src": "/script.js", "dest": "/web/script.js" },
    { "src": "/programs", "dest": "/web/programs.html" },
    { "src": "/(.*)", "dest": "/web/index.html" }
  ]
}
